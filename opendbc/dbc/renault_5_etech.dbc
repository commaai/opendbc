VAL_ 1100 GEAR_DIRECTION 1 "REVERSE" 2 "STATIONARY_PN" 3 "FORWARD_DB" ;
VAL_ 1402 ADAS_STATE 0 "ACTIVE_ASSIST_CONTROLLING" 1 "INIT_BOOT" 8 "ARMED" 16 "LONGITUDINAL_ACTIVE_OR_DRIVER_OVERRIDE" 41 "FAULT" ;
VAL_ 1402 ADAS_MODE_STATE 2 "ACTIVE_ASSIST_CONTROLLING" 64 "OFF_OR_ARMED" 65 "ACTIVE_ASSIST_SELECTED" 144 "LONGITUDINAL_ONLY_OR_OVERRIDE" 145 "ACTIVE_ASSIST_DRIVER_OVERRIDE" ;
VAL_ 427 LKAS_STATE 1 "ACTIVE_OR_READY" 2 "SUPPRESSED_BY_DRIVER" 3 "UNAVAILABLE" ;
