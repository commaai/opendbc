VAL_ 220 ST_INTF_DRASY_TAR_LIM 0 "Fahrpedal nicht getreten, keine FAS-Anforderung" 1 "Fahrpedal nicht getreten, Fahreranforderung kleiner FAS-Sollmoment-TAR" 2 "Fahrpedal nicht getreten, Fahreranforderung größer FAS-Sollmoment-TAR UND/ODER Fahreranforderung kleiner FAS-Sollmoment-LIM" 3 "Fahrpedal nicht getreten, Fahreranforderung größer FAS-Sollmoment-LIM" 4 "Fahrpedal getreten, keine FAS-Anforderung" 5 "Fahrpedal getreten, Fahreranforderung kleiner FAS-Sollmoment-TAR" 6 "Fahrpedal getreten, Fahreranforderung größer FAS-Sollmoment-TAR UND/ODER Fahreranforderung kleiner FAS-Sollmoment-LIM" 7 "Fahrpedal getreten, Fahreranforderung größer FAS-Sollmoment-LIM" 13 "SIGNALTAG_FCTIF_NOT_AVAILABLE" 14 "SIGNALTAG_FCT_ERROR" 15 "Sendefunktion nicht in Betrieb";
VAL_ 220 ST_DRVDIR_DVCH 0 "Initialisierung" 2 "Park oder Neutral, beim Handschalter: kein Kraftschluss" 4 "CVT, Gang 1-9, Handschalter: kein Rückwärtsgang und Kraftschluss erkannt" 5 "Rückwärtsgang" 15 "Signal ungültig";
VAL_ 220 QU_AVL_RPM_BAX_RED 2 "Normalzustand" 6 "Fehler" 7 "Handschalter" 8 "Beim Erststart des Steuergeräts: Bis gelernte Hinterachsübersetzung > 0" 15 "Darf ausschließlich durch ein Gateway gesetzt werden";
VAL_ 220 ST_AVAI_INTV_PT_DRS 0 "Eingriff nicht erlaubt wegen GWS-Betätigung" 1 "Eingriff erlaubt" 2 "Eingriff nicht erlaubt" 3 "Wird funktional nicht versendet.";
VAL_ 220 CTR_ACTVN_PWHOP 0 "Power Hop - Keine Bremsunterstützung angefordert" 1 "Power Hop aktiv - Anforderung Bremsunterstützung Schwelle 1" 2 "Power Hop aktiv - Anforderung Bremsunterstützung Schwelle 2" 3 "Wird gesetzt wenn die Funktion nicht verbaut ist.";
